<?php
function horaEspejo($horaStr) {
    list($h, $m) = explode(":", $horaStr);
    
    $h = intval($h);
    $m = intval($m);
    
    // Convertir a minutos
    $totalMin = ($h % 12) * 60 + $m;
    
    // Minutos espejo
    $espejoMin = (12 * 60 - $totalMin) % (12 * 60);
    
    // Convertir nuevamente
    $hEspejo = intdiv($espejoMin, 60);
    $mEspejo = $espejoMin % 60;
    
    if ($hEspejo == 0) {
        $hEspejo = 12;
    }
    
    return sprintf("%02d:%02d", $hEspejo, $mEspejo);
}

